<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
<title>OVERWORLD // map scan</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@400;600;700&family=Major+Mono+Display&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#05070d; --panel:#0a0f1aee; --line:#1b2c44;
    --cy:#19e6ff; --gn:#34ff9e; --bl:#3b9bff; --mg:#ff3ea5; --tx:#bfe9ff;
  }
  *{margin:0;padding:0;box-sizing:border-box}
  html,body{width:100%;height:100%;overflow:hidden;background:var(--bg);color:var(--tx);
    font-family:'Chakra Petch',monospace;-webkit-tap-highlight-color:transparent;overscroll-behavior:none}
  #c{position:fixed;inset:0;display:block;touch-action:none}
  /* ---- control panel ---- */
  #ui{position:fixed;top:12px;left:12px;width:264px;max-width:calc(100vw - 24px);
    background:var(--panel);border:1px solid var(--line);border-radius:10px;padding:13px 13px 11px;
    backdrop-filter:blur(8px);box-shadow:0 8px 40px #000a, inset 0 0 0 1px #ffffff08;z-index:10}
  #ui h1{font-family:'Major Mono Display',monospace;font-size:15px;letter-spacing:1px;color:var(--cy);
    text-shadow:0 0 12px #19e6ff66;margin-bottom:2px;font-weight:400}
  #ui .sub{font-size:9.5px;letter-spacing:3px;color:#5b7aa0;text-transform:uppercase;margin-bottom:11px}
  label{display:block;font-size:9px;letter-spacing:2px;text-transform:uppercase;color:#6f93bd;margin:9px 0 3px}
  select,input{width:100%;background:#0b1220;border:1px solid var(--line);color:var(--tx);
    font-family:'Chakra Petch',monospace;font-size:12px;padding:7px 8px;border-radius:6px;outline:none}
  select:focus,input:focus{border-color:var(--cy);box-shadow:0 0 0 1px #19e6ff44}
  .row{display:flex;gap:7px}.row>div{flex:1}
  #go{width:100%;margin-top:12px;padding:9px;background:linear-gradient(180deg,#0e2436,#0a1828);
    border:1px solid var(--cy);color:var(--cy);font-family:'Chakra Petch',monospace;font-weight:700;
    font-size:12px;letter-spacing:3px;border-radius:7px;cursor:pointer;text-transform:uppercase;
    transition:all .15s;text-shadow:0 0 8px #19e6ff66}
  #go:hover{background:#103047;box-shadow:0 0 20px #19e6ff44}
  #go:active{transform:translateY(1px)}
  #go:disabled{opacity:.4;cursor:wait;border-color:var(--line);color:#5b7aa0;text-shadow:none}
  .hint{font-size:9px;color:#4d688c;margin-top:9px;line-height:1.5;letter-spacing:.5px}
  /* ---- stats / legend ---- */
  #stats{position:fixed;bottom:12px;left:12px;font-size:10px;letter-spacing:1px;color:#5b7aa0;
    background:var(--panel);border:1px solid var(--line);border-radius:8px;padding:8px 11px;z-index:10;
    backdrop-filter:blur(8px);line-height:1.7}
  #stats b{color:var(--cy);font-weight:700}
  #stats .lg{display:inline-block;width:9px;height:9px;border-radius:2px;margin-right:5px;vertical-align:-1px}
  /* ---- loader ---- */
  #load{position:fixed;inset:0;display:none;align-items:center;justify-content:center;flex-direction:column;
    background:#05070dcc;z-index:20;backdrop-filter:blur(2px)}
  #load.on{display:flex}
  .scan{width:120px;height:120px;border:1px solid #19e6ff33;border-radius:50%;position:relative;
    box-shadow:0 0 40px #19e6ff22, inset 0 0 30px #19e6ff11}
  .scan::before{content:'';position:absolute;inset:-1px;border-radius:50%;border-top:2px solid var(--cy);
    border-right:2px solid transparent;animation:spin 1s linear infinite}
  @keyframes spin{to{transform:rotate(360deg)}}
  #load p{margin-top:18px;font-size:11px;letter-spacing:4px;color:var(--cy);text-transform:uppercase;
    text-shadow:0 0 10px #19e6ff66}
  #err{position:fixed;left:50%;bottom:22px;transform:translateX(-50%);z-index:21;display:none;cursor:pointer;
    background:#1a0a12ee;border:1px solid var(--mg);border-radius:10px;padding:18px 22px;max-width:300px;
    text-align:center;color:#ffd0e4}
  #err.on{display:block}
  #err b{color:var(--mg);letter-spacing:2px;display:block;margin-bottom:7px}
  #err small{font-size:10px;color:#c98ba8;line-height:1.5}
  #err .dz{display:block;margin-top:8px;font-size:9px;letter-spacing:2px;color:#c98ba877}
  .corner{position:fixed;width:18px;height:18px;border:1px solid #19e6ff44;z-index:5;pointer-events:none}
  .c1{top:6px;left:6px;border-right:0;border-bottom:0}.c2{top:6px;right:6px;border-left:0;border-bottom:0}
  .c3{bottom:6px;left:6px;border-right:0;border-top:0}.c4{bottom:6px;right:6px;border-left:0;border-top:0}
</style>
</head>
<body>
<canvas id="c"></canvas>
<div class="corner c1"></div><div class="corner c2"></div><div class="corner c3"></div><div class="corner c4"></div>

<div id="ui">
  <h1>overworld</h1>
  <div class="sub">map &rarr; mesh scanner</div>

  <label>Location preset</label>
  <select id="preset">
    <option value="40.7484,-73.9857">New York · Midtown grid</option>
    <option value="48.8584,2.2945">Paris · Champ de Mars</option>
    <option value="37.7946,-122.3999">San Francisco · Financial</option>
    <option value="45.4371,12.3326">Venice · canals</option>
    <option value="51.5101,-0.1340">London · Soho</option>
    <option value="35.6595,139.7005">Tokyo · Shibuya</option>
    <option value="custom">— custom lat, lon —</option>
  </select>

  <div class="row" id="customrow" style="display:none">
    <div><label>Lat</label><input id="lat" value="40.7484"></div>
    <div><label>Lon</label><input id="lon" value="-73.9857"></div>
  </div>

  <label>Scan radius · <span id="rlbl">350</span> m</label>
  <input id="rad" type="range" min="150" max="700" step="50" value="350" style="padding:0;height:24px">

  <button id="go">▶ scan area</button>
  <div class="hint" id="hint">Drag to orbit · pinch / scroll to zoom · two&#8209;finger drag to pan · WASD to fly. Live data from OpenStreetMap.</div>
</div>

<div id="stats">
  <div><span class="lg" style="background:#19e6ff"></span><b id="sB">0</b> buildings</div>
  <div><span class="lg" style="background:#9fb4cf"></span><b id="sR">0</b> roads</div>
  <div><span class="lg" style="background:#34ff9e"></span><b id="sT">0</b> trees</div>
</div>

<div id="load"><div class="scan"></div><p id="ldtxt">scanning…</p></div>
<div id="err"><b>SCAN FAILED</b><small id="errtxt"></small></div>

<script>
  window.addEventListener('error',e=>{ const x=document.getElementById('err'); if(x){ x.classList.add('on'); document.getElementById('errtxt').textContent=(e.message||'error')+'  ['+((e.filename||'').split('/').pop())+':'+e.lineno+']'; } });
  window.addEventListener('unhandledrejection',e=>{ const x=document.getElementById('err'); if(x){ x.classList.add('on'); document.getElementById('errtxt').textContent='promise: '+((e.reason&&e.reason.message)||e.reason||''); } });
  setTimeout(()=>{ if(!window.__mapReady){ const x=document.getElementById('err'); if(x){ x.classList.add('on'); document.getElementById('errtxt').innerHTML='3D engine did not start &mdash; the artifact viewer may be blocking the CDN. Open this file in a normal browser tab (download / host it).'; } } },5000);
</script>
<script type="importmap">
{ "imports": {
  "three": "https://cdnjs.cloudflare.com/ajax/libs/three.js/0.160.0/three.module.min.js",
  "three/addons/": "https://cdn.jsdelivr.net/npm/three@0.160.0/examples/jsm/"
}}
</script>

<script type="module">
import * as THREE from 'three';
import { OrbitControls } from 'three/addons/controls/OrbitControls.js';
import { mergeGeometries } from 'three/addons/utils/BufferGeometryUtils.js';

// ───────────────────────── scene ─────────────────────────
const canvas = document.getElementById('c');
const renderer = new THREE.WebGLRenderer({ canvas, antialias:true });
renderer.setPixelRatio(Math.min(devicePixelRatio, 2));
renderer.outputColorSpace = THREE.SRGBColorSpace;

const scene = new THREE.Scene();
scene.background = new THREE.Color(0x05070d);
scene.fog = new THREE.Fog(0x05070d, 600, 2200);

const camera = new THREE.PerspectiveCamera(58, innerWidth/innerHeight, 1, 6000);
camera.position.set(0, 380, 420);

const controls = new OrbitControls(camera, canvas);
controls.enableDamping = true;
controls.dampingFactor = 0.08;
controls.maxPolarAngle = Math.PI*0.495;   // never go under the ground
controls.minDistance = 40;
controls.maxDistance = 2400;
controls.target.set(0,0,0);
window.__mapReady=true;

scene.add(new THREE.HemisphereLight(0x9fd6ff, 0x0a0f1a, 0.65));
const sun = new THREE.DirectionalLight(0xffffff, 0.9); sun.position.set(300,600,200); scene.add(sun);

// ground + grid
const ground = new THREE.Mesh(
  new THREE.PlaneGeometry(8000,8000),
  new THREE.MeshStandardMaterial({ color:0x070b13, roughness:1, metalness:0 }));
ground.rotation.x = -Math.PI/2; ground.position.y = -0.5; scene.add(ground);
const grid = new THREE.GridHelper(4000, 80, 0x2a5a82, 0x163a56);
grid.position.y = -0.4; scene.add(grid);

// holder for generated world (cleared each scan)
let world = new THREE.Group(); scene.add(world);

// ───────────────────────── helpers ─────────────────────────
const $ = id => document.getElementById(id);
const M_LAT = 110540;                                   // metres per degree latitude
const mLon  = lat => 111320 * Math.cos(lat*Math.PI/180); // metres per degree longitude

function project(lat, lon, cLat, cLon){
  return { x:(lon-cLon)*mLon(cLat), z:-(lat-cLat)*M_LAT };
}
function pointInPoly(x, z, pts){          // ray-cast, pts = [{x,z}…]
  let inside=false;
  for(let i=0,j=pts.length-1;i<pts.length;j=i++){
    const xi=pts[i].x, zi=pts[i].z, xj=pts[j].x, zj=pts[j].z;
    if(((zi>z)!==(zj>z)) && (x < (xj-xi)*(z-zi)/(zj-zi)+xi)) inside=!inside;
  }
  return inside;
}

// road widths by class (metres)
const ROADW = { motorway:14, trunk:12, primary:10, secondary:8, tertiary:7,
  residential:5.5, unclassified:5, service:3.5, living_street:5, pedestrian:4,
  footway:2, path:1.8, cycleway:2.4 };

// ───────────────────────── build ─────────────────────────
function buildWorld(elements, cLat, cLon){
  scene.remove(world);
  world.traverse(o=>{ if(o.geometry)o.geometry.dispose(); if(o.material)o.material.dispose(); });
  world = new THREE.Group(); scene.add(world);

  const bGeos=[], bEdges=[], roadGeos=[], parkGeos=[], waterGeos=[], treePts=[];
  let nB=0,nR=0;

  for(const el of elements){
    if(el.type!=='way' || !el.geometry || el.geometry.length<2) continue;
    const t = el.tags||{};
    const pts = el.geometry.map(g=>project(g.lat, g.lon, cLat, cLon));

    if(t.building){
      if(nB>=2000) continue;
      const lvls = parseFloat(t['building:levels']);
      const h = t.height ? parseFloat(t.height)
              : (lvls ? lvls*3.4 : 6 + Math.random()*Math.random()*34);
      const g = extrude(pts, Math.max(3,h));
      if(g){ bGeos.push(g); const e=new THREE.EdgesGeometry(g,28); bEdges.push(e); nB++; }
    }
    else if(t.highway && ROADW[t.highway]!==undefined){
      const g = ribbon(pts, ROADW[t.highway]); if(g){ roadGeos.push(g); nR++; }
    }
    else if(t.leisure==='park'||t.leisure==='garden'||t.landuse==='grass'
          || t.landuse==='meadow'||t.landuse==='recreation_ground'||t.natural==='wood'||t.landuse==='forest'){
      const g = flat(pts, 0.06); if(g){ parkGeos.push(g);
        scatter(pts, t.natural==='wood'||t.landuse==='forest'?0.0016:0.0006, treePts); }
    }
    else if(t.natural==='water'||t.waterway){
      const g = flat(pts, 0.12); if(g) waterGeos.push(g);
    }
  }

  // merge & add
  const add=(geos,mat)=>{ if(!geos.length)return null; const m=mergeGeometries(geos,false);
    if(!m)return null; const mesh=new THREE.Mesh(m,mat); world.add(mesh); return mesh; };

  const parkMesh  = add(parkGeos,  new THREE.MeshStandardMaterial({color:0x0c2a17,emissive:0x0c3a1c,emissiveIntensity:.35,roughness:1}));
  const waterMesh = add(waterGeos, new THREE.MeshStandardMaterial({color:0x081f3e,emissive:0x103a6e,emissiveIntensity:.5,roughness:.3,metalness:.4}));
  const roadMesh  = add(roadGeos,  new THREE.MeshStandardMaterial({color:0x1a2233,emissive:0x0a1322,emissiveIntensity:.6,roughness:.9}));

  const bMesh = add(bGeos, new THREE.MeshStandardMaterial({color:0x14233d,emissive:0x0a1830,emissiveIntensity:.45,roughness:.55,metalness:.25,flatShading:true}));
  let eMesh=null;
  if(bEdges.length){ const em=mergeGeometries(bEdges,false);
    if(em) eMesh = new THREE.LineSegments(em, new THREE.LineBasicMaterial({color:0x19e6ff,transparent:true,opacity:.55})); if(eMesh) world.add(eMesh); }

  // trees (one merged mesh)
  let nT=0;
  if(treePts.length){
    const tmpl = treeTemplate();
    const tg=[];
    for(const p of treePts){ if(nT>=900)break; const c=tmpl.clone(); c.translate(p.x, 0, p.z); tg.push(c); nT++; }
    if(tg.length){ const tm=mergeGeometries(tg,false);
      if(tm) world.add(new THREE.Mesh(tm, new THREE.MeshStandardMaterial({color:0x1f7a45,emissive:0x0d3a20,emissiveIntensity:.4,roughness:1,flatShading:true}))); }
  }

  // rise-up reveal animation
  const risers = [bMesh, eMesh].filter(Boolean);
  for(const r of risers) r.scale.y = 0.001;
  reveal.t = 0; reveal.on = true; reveal.risers = risers;

  $('sB').textContent=nB; $('sR').textContent=nR; $('sT').textContent=nT;

  // frame the camera to the data
  const span = Math.max(120, currentRadius*1.4);
  controls.target.set(0,0,0);
window.__mapReady=true;
  camera.position.set(span*0.55, span*0.85, span*0.95);
}
const reveal = { on:false, t:0, risers:[] };

// extrude a footprint polygon up by h  (shape uses (x,-z) so rotateX lands it at world x,z)
function extrude(pts, h){
  if(pts.length<3) return null;
  const s = new THREE.Shape();
  s.moveTo(pts[0].x, -pts[0].z);
  for(let i=1;i<pts.length;i++) s.lineTo(pts[i].x, -pts[i].z);
  let g;
  try{ g = new THREE.ExtrudeGeometry(s, {depth:h, bevelEnabled:false, steps:1}); }
  catch(e){ return null; }
  g.rotateX(-Math.PI/2);
  return g;
}
// flat filled polygon at height y
function flat(pts, y){
  if(pts.length<3) return null;
  const s = new THREE.Shape();
  s.moveTo(pts[0].x, -pts[0].z);
  for(let i=1;i<pts.length;i++) s.lineTo(pts[i].x, -pts[i].z);
  let g; try{ g = new THREE.ShapeGeometry(s); }catch(e){ return null; }
  g.rotateX(-Math.PI/2); g.translate(0,y,0);
  return g;
}
// ribbon along a polyline, width w, flat at y=0.2
function ribbon(pts, w){
  const hw=w/2, pos=[], nrm=[];
  for(let i=0;i<pts.length-1;i++){
    const a=pts[i], b=pts[i+1];
    let dx=b.x-a.x, dz=b.z-a.z; const L=Math.hypot(dx,dz)||1; dx/=L; dz/=L;
    const px=-dz*hw, pz=dx*hw, y=0.2;
    const a1=[a.x+px,y,a.z+pz], a2=[a.x-px,y,a.z-pz], b1=[b.x+px,y,b.z+pz], b2=[b.x-px,y,b.z-pz];
    pos.push(...a1,...b1,...a2, ...b1,...b2,...a2);
    for(let k=0;k<6;k++) nrm.push(0,1,0);
  }
  if(!pos.length) return null;
  const g=new THREE.BufferGeometry();
  g.setAttribute('position', new THREE.Float32BufferAttribute(pos,3));
  g.setAttribute('normal',   new THREE.Float32BufferAttribute(nrm,3));
  return g;
}
// scatter tree points inside a polygon (density per m²)
function scatter(pts, density, out){
  let minX=1e9,maxX=-1e9,minZ=1e9,maxZ=-1e9;
  for(const p of pts){ minX=Math.min(minX,p.x);maxX=Math.max(maxX,p.x);minZ=Math.min(minZ,p.z);maxZ=Math.max(maxZ,p.z); }
  const area=(maxX-minX)*(maxZ-minZ); let n=Math.min(120, Math.floor(area*density));
  let guard=0;
  while(n>0 && guard<n*12){ guard++;
    const x=minX+Math.random()*(maxX-minX), z=minZ+Math.random()*(maxZ-minZ);
    if(pointInPoly(x,z,pts)){ out.push({x,z}); n--; }
  }
}
function treeTemplate(){
  const tr=new THREE.CylinderGeometry(0.6,0.9,3,5); tr.translate(0,1.5,0);
  const ht=3.5+Math.random()*3;
  const cn=new THREE.ConeGeometry(2.4,ht,6); cn.translate(0,3+ht/2,0);
  return mergeGeometries([tr,cn],false);
}

// ───────────────────────── fetch ─────────────────────────
let currentRadius=350;
const MIRRORS=[
  'https://overpass-api.de/api/interpreter',
  'https://overpass.kumi.systems/api/interpreter'
];
async function scan(lat, lon, rad){
  currentRadius=rad;
  const dLat=rad/M_LAT, dLon=rad/mLon(lat);
  const S=lat-dLat, N=lat+dLat, W=lon-dLon, E=lon+dLon;
  const q=`[out:json][timeout:30];(`+
    `way["building"](${S},${W},${N},${E});`+
    `way["highway"](${S},${W},${N},${E});`+
    `way["leisure"~"park|garden"](${S},${W},${N},${E});`+
    `way["landuse"~"grass|forest|meadow|recreation_ground"](${S},${W},${N},${E});`+
    `way["natural"~"water|wood"](${S},${W},${N},${E});`+
    `way["waterway"](${S},${W},${N},${E});`+
    `);out geom;`;
  let lastErr;
  for(const url of MIRRORS){
    try{
      const res=await fetch(url,{method:'POST',body:'data='+encodeURIComponent(q)});
      if(!res.ok) throw new Error('HTTP '+res.status);
      const json=await res.json();
      return json.elements||[];
    }catch(e){ lastErr=e; }
  }
  throw lastErr||new Error('all mirrors failed');
}

// ───────────────────────── UI ─────────────────────────
$('preset').onchange=e=>{
  const v=e.target.value;
  $('customrow').style.display = v==='custom'?'flex':'none';
  if(v!=='custom'){ const [la,lo]=v.split(','); $('lat').value=la; $('lon').value=lo; }
};
{ const _r=$('rad'), _l=$('rlbl'); const _u=()=>{ _l.textContent=_r.value; };
  _r.addEventListener('input',_u); _r.addEventListener('change',_u); _u(); }

async function run(){
  const lat=parseFloat($('lat').value), lon=parseFloat($('lon').value), rad=parseInt($('rad').value);
  if(isNaN(lat)||isNaN(lon)){ showErr('Invalid coordinates.'); return; }
  $('err').classList.remove('on');
  $('load').classList.add('on'); $('ldtxt').textContent='scanning…'; $('go').disabled=true;
  try{
    const els=await scan(lat,lon,rad);
    $('ldtxt').textContent='building mesh…';
    await new Promise(r=>setTimeout(r,30));
    if(!els.length){ showErr('No map data in this area. Try a different spot or larger radius.'); }
    else buildWorld(els, lat, lon);
  }catch(e){
    showErr('Overpass API unavailable or rate&#8209;limited. Wait a few seconds and try again, or shrink the radius. ('+(e.message||e)+')');
  }finally{
    $('load').classList.remove('on'); $('go').disabled=false;
  }
}
function showErr(msg){ console.error('[overworld]', msg); $('errtxt').innerHTML=msg+'<span class=\"dz\">TAP TO DISMISS</span>'; $('err').classList.add('on'); }
$('go').onclick=run;
$('err').onclick=()=>$('err').classList.remove('on');

// WASD fly (moves both camera & target on the ground plane)
const keys={};
addEventListener('keydown',e=>keys[e.code]=true);
addEventListener('keyup',e=>keys[e.code]=false);
function fly(dt){
  const sp=controls.getDistance()*1.2*dt;
  const f=new THREE.Vector3(); camera.getWorldDirection(f); f.y=0; f.normalize();
  const r=new THREE.Vector3().crossVectors(f,camera.up).normalize();
  const mv=new THREE.Vector3();
  if(keys['KeyW'])mv.add(f); if(keys['KeyS'])mv.sub(f);
  if(keys['KeyD'])mv.add(r); if(keys['KeyA'])mv.sub(r);
  if(mv.lengthSq()){ mv.normalize().multiplyScalar(sp); camera.position.add(mv); controls.target.add(mv); }
}

// ───────────────────────── loop ─────────────────────────
addEventListener('resize',()=>{ camera.aspect=innerWidth/innerHeight; camera.updateProjectionMatrix();
  renderer.setSize(innerWidth,innerHeight); });
renderer.setSize(innerWidth,innerHeight);

let last=performance.now();
function tick(now){
  const dt=Math.min(0.05,(now-last)/1000); last=now;
  if(reveal.on){ reveal.t=Math.min(1, reveal.t+dt/1.1);
    const e=1-Math.pow(1-reveal.t,3);                 // ease-out cubic
    for(const r of reveal.risers) r.scale.y=Math.max(0.001,e);
    if(reveal.t>=1) reveal.on=false;
  }
  fly(dt); controls.update();
  renderer.render(scene,camera);
  requestAnimationFrame(tick);
}
requestAnimationFrame(tick);

// first scan on load
run();
</script>
</body>
</html>
